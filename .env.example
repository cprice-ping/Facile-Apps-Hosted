# Example environment variables for Facile-Apps-Hosted
# Copy this file to .env and fill in the required values before running the app.

# Server port (default: 3000)
PORT=3000

# SingularKey (SK) credentials
SK_COMPANY_ID=your_singular_key_company_id
SK_API_KEY=your_singular_key_api_key

# PingOne Risk credentials and environment
RISK_ENV_ID=your_pingone_risk_environment_id
RISK_CLIENT_ID=your_pingone_risk_client_id
RISK_CLIENT_SECRET=your_pingone_risk_client_secret

# PingFederate Reference ID Adapter credentials
PF_ADAPTER_USER=your_pf_adapter_username
PF_ADAPTER_PWD=your_pf_adapter_password

# CORS origin (e.g., http://localhost:3000), default '*' allows all
CORS_ORIGIN=*